# ===== 환경 변수 설정 파일 =====
# 이 파일을 .env 로 복사하여 실제 값을 입력하세요.

# 데이터베이스 URL (개발: SQLite / 운영: PostgreSQL)
DATABASE_URL=sqlite:///./bonus_score.db
# DATABASE_URL=postgresql://user:password@localhost:5432/bonus_score_db

# JWT 설정
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# 관리자 계정
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin1234

# 외부 API 키 (잡알리오 / 공공데이터포털)
JOBALIO_API_KEY=your_jobalio_api_key_here
PUBLIC_DATA_API_KEY=your_public_data_api_key_here

# CORS 허용 출처
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5500
